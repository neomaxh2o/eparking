# eparking - example environment variables (placeholders only)

# Public keys (safe to be public but include placeholder)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
NEXT_PUBLIC_DEBUG_PARKING=false

# App configuration
NEXTAUTH_URL=https://staging.example.com
NEXTAUTH_SECRET=PLACEHOLDER_NEXTAUTH_SECRET

# Database
MONGODB_URI=PLACEHOLDER_MONGODB_URI

# Payment / webhooks
ABONADOS_PAYMENT_WEBHOOK_SECRET=PLACEHOLDER_WEBHOOK_SECRET

# OAuth providers
GOOGLE_ID=PLACEHOLDER_GOOGLE_ID
GOOGLE_SECRET=PLACEHOLDER_GOOGLE_SECRET
INSTAGRAM_CLIENT_ID=PLACEHOLDER
INSTAGRAM_CLIENT_SECRET=PLACEHOLDER

# AWS (if used)
AWS_ACCESS_KEY_ID=PLACEHOLDER_AWS_KEY
AWS_SECRET_ACCESS_KEY=PLACEHOLDER_AWS_SECRET

# Other (add as needed)
SENTRY_DSN=PLACEHOLDER_SENTRY_DSN
# END
