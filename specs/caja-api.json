{
  "version": "1.0",
  "basePath": "/api",
  "endpoints": [
    {
      "path": "/shifts/open",
      "method": "POST",
      "roles": ["cashier","admin"],
      "description": "Open a new shift for a store",
      "request": {
        "type": "object",
        "required": ["storeId","startingCash"],
        "properties": {
          "storeId": {"type":"string","format":"objectId"},
          "startingCash": {"type":"integer","minimum":0},
          "notes": {"type":"string"}
        }
      },
      "response": {
        "201": {"$ref":"#/components/schemas/Shift"},
        "409": {"type":"object","properties":{"error":{"type":"string"}}}
      }
    },
    {
      "path": "/shifts",
      "method": "GET",
      "roles": ["cashier","manager","admin"],
      "description": "List shifts - filter by storeId and status",
      "query": {
        "storeId": {"type":"string","format":"objectId"},
        "status": {"type":"string","enum":["open","closed","suspended"]}
      },
      "response": {"200": {"type":"array","items":{"$ref":"#/components/schemas/Shift"}}}
    },
    {
      "path": "/shifts/{id}",
      "method": "GET",
      "roles": ["cashier","manager","admin"],
      "params": {"id":{"type":"string","format":"objectId"}},
      "response": {"200":{"$ref":"#/components/schemas/Shift"},"404":{"type":"object"}}
    },
    {
      "path": "/shifts/{id}/close",
      "method": "POST",
      "roles": ["cashier","manager","admin"],
      "params": {"id":{"type":"string","format":"objectId"}},
      "request": {
        "type":"object",
        "required": ["actualCash"],
        "properties": {
          "actualCash": {"type":"integer","minimum":0},
          "notes": {"type":"string"}
        }
      },
      "response": {"200":{"$ref":"#/components/schemas/Shift"},"400":{"type":"object"}}
    },
    {
      "path": "/tickets",
      "method": "POST",
      "roles": ["cashier","admin"],
      "description": "Create a ticket associated to an open shift",
      "request": {
        "type":"object",
        "required": ["shiftId","storeId","items","paymentMethod"],
        "properties": {
          "shiftId": {"type":"string","format":"objectId"},
          "storeId": {"type":"string","format":"objectId"},
          "items": {"type":"array","minItems":1,"items":{
            "type":"object",
            "required":["sku","name","qty","unitPrice"],
            "properties":{
              "sku":{"type":"string"},
              "name":{"type":"string"},
              "qty":{"type":"number","minimum":0.001},
              "unitPrice":{"type":"integer","minimum":0}
            }
          }},
          "paymentMethod": {"type":"string","enum":["cash","card","other"]},
          "payments": {"type":"array","items": {"type":"object","required":["method","amount"],"properties":{"method":{"type":"string"},"amount":{"type":"integer","minimum":0},"reference":{"type":"string"}}}},
          "notes": {"type":"string"}
        }
      },
      "response": {"201":{"$ref":"#/components/schemas/Ticket"},"400":{"type":"object"}}
    },
    {
      "path": "/tickets/{id}",
      "method": "GET",
      "roles": ["cashier","manager","admin"],
      "params": {"id":{"type":"string","format":"objectId"}},
      "response": {"200":{"$ref":"#/components/schemas/Ticket"},"404":{"type":"object"}}
    },
    {
      "path": "/cash-movements",
      "method": "POST",
      "roles": ["cashier","manager","admin"],
      "request": {
        "type":"object",
        "required": ["storeId","type","amount"],
        "properties": {
          "shiftId": {"type":"string","format":"objectId"},
          "storeId": {"type":"string","format":"objectId"},
          "type": {"type":"string","enum":["in","out","adjustment"]},
          "amount": {"type":"integer","minimum":1},
          "reason": {"type":"string"},
          "reference": {"type":"string"}
        }
      },
      "response": {"201":{"$ref":"#/components/schemas/CashMovement"},"400":{"type":"object"}}
    },
    {
      "path": "/reports/shift/{id}",
      "method": "GET",
      "roles": ["cashier","manager","admin"],
      "params": {"id":{"type":"string","format":"objectId"}},
      "response": {
        "200": {
          "type":"object",
          "properties": {
            "shift": {"$ref":"#/components/schemas/Shift"},
            "tickets": {"type":"array","items":{"$ref":"#/components/schemas/Ticket"}},
            "cashMovements": {"type":"array","items":{"$ref":"#/components/schemas/CashMovement"}},
            "summary": {"type":"object","properties":{
              "ticketsTotal":{"type":"integer"},
              "cashMovementsTotal":{"type":"integer"},
              "expectedCash":{"type":"integer"},
              "actualCash":{"type":"integer"},
              "difference":{"type":"integer"}
            }}
          }
        }
      }
    }
  ],
  "components": {
    "schemas": {
      "Shift": {
        "type":"object",
        "properties":{
          "_id":{"type":"string","format":"objectId"},
          "storeId":{"type":"string"},
          "openedBy":{"type":"string"},
          "openedAt":{"type":"string","format":"date-time"},
          "closedBy":{"type":"string","nullable":true},
          "closedAt":{"type":"string","format":"date-time","nullable":true},
          "status":{"type":"string","enum":["open","closed","suspended"]},
          "startingCash":{"type":"integer"},
          "expectedCash":{"type":"integer"},
          "actualCash":{"type":"integer","nullable":true},
          "ticketsCount":{"type":"integer"},
          "ticketsTotal":{"type":"integer"},
          "cashMovementsTotal":{"type":"integer"},
          "notes":{"type":"string"},
          "createdAt":{"type":"string","format":"date-time"},
          "updatedAt":{"type":"string","format":"date-time"}
        }
      },
      "Ticket": {
        "type":"object",
        "properties":{
          "_id":{"type":"string"},
          "shiftId":{"type":"string"},
          "storeId":{"type":"string"},
          "createdBy":{"type":"string"},
          "createdAt":{"type":"string"},
          "status":{"type":"string"},
          "total":{"type":"integer"},
          "items":{"type":"array"},
          "paymentMethod":{"type":"string"},
          "payments":{"type":"array"},
          "notes":{"type":"string"}
        }
      },
      "CashMovement": {
        "type":"object",
        "properties":{
          "_id":{"type":"string"},
          "shiftId":{"type":"string","nullable":true},
          "storeId":{"type":"string"},
          "createdBy":{"type":"string"},
          "createdAt":{"type":"string"},
          "type":{"type":"string"},
          "amount":{"type":"integer"},
          "direction":{"type":"string"},
          "reason":{"type":"string"},
          "reference":{"type":"string"}
        }
      }
    }
  }
}
